# ── AI 설정 (Groq 또는 Gemini 중 하나만 입력하면 됩니다) ──────
# Groq (무료, 추천): https://console.groq.com 에서 발급
GROQ_API_KEY=여기에_Groq_API_키_입력
# 사용할 Groq 모델 (기본값: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (대안): https://aistudio.google.com/app/apikey 에서 발급
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

SESSION_SECRET=랜덤한_긴_문자열_아무거나
PORT=3000

# NAS 업로드 경로 (설정하면 사진이 NAS에 저장됨)
# 윈도우 예시: NAS_UPLOAD_PATH=Z:\dcprime-uploads
# 윈도우 예시: NAS_UPLOAD_PATH=\\192.168.0.10\공유폴더\dcprime-uploads
# 맥/리눅스:  NAS_UPLOAD_PATH=/Volumes/NAS/dcprime-uploads
# 비워두면 서버 로컬(public/uploads/)에 저장
NAS_UPLOAD_PATH=
